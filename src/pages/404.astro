---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found — Freelancer Tax Estimator"
  description="That page doesn't exist (or moved). Try the calculator, the guides index, or the homepage."
  noindex={true}
>
  <section class="mx-auto max-w-2xl px-4 py-20 text-center">
    <p class="text-sm uppercase tracking-wider opacity-60">404</p>
    <h1 class="mt-2 text-3xl font-extrabold">Page not found</h1>
    <p class="mt-4 text-slate-600 dark:text-slate-400">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700"
        >Open the calculator</a
      >
      <a
        href="/guides"
        class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800"
        >Browse guides</a
      >
    </div>
  </section>
</BaseLayout>

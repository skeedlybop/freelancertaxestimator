---
/**
 * FicaPie — two-segment donut showing the FICA split for self-employment tax.
 * 12.4% Social Security + 2.9% Medicare = 15.3% combined.
 * Values are driven by tax-constants.ts so a rate change updates the chart.
 */
import { SE_TAX } from "@/data/tax-constants";

const ss = SE_TAX.socialSecurityRate;
const med = SE_TAX.medicareRate;
const total = SE_TAX.totalRate;

// Two arcs on a donut. Convert percentages to stroke-dasharray fractions
// of a circle whose circumference is 2πr. We'll use r=45 for a 100-wide
// viewBox, circumference = 282.7.
const r = 45;
const c = 2 * Math.PI * r;
const ssLen = (ss / total) * c;
const medLen = (med / total) * c;
---

<figure class="my-8 mx-auto max-w-md">
  <div class="card flex flex-col items-center p-6">
    <svg
      viewBox="0 0 100 100"
      class="h-48 w-48 -rotate-90"
      role="img"
      aria-labelledby="fica-pie-title fica-pie-desc"
    >
      <title id="fica-pie-title">2026 self-employment tax breakdown</title>
      <desc id="fica-pie-desc">
        Donut chart showing the {(total * 100).toFixed(1)}% combined SE tax split
        between {(ss * 100).toFixed(1)}% Social Security and {(med * 100).toFixed(1)}% Medicare.
      </desc>
      <circle cx="50" cy="50" r={r} fill="none" stroke="#e2e8f0" stroke-width="10" class="dark:stroke-slate-800" />
      <circle
        cx="50"
        cy="50"
        r={r}
        fill="none"
        stroke="#4f46e5"
        stroke-width="10"
        stroke-dasharray={`${ssLen} ${c - ssLen}`}
        stroke-dashoffset="0"
      />
      <circle
        cx="50"
        cy="50"
        r={r}
        fill="none"
        stroke="#10b981"
        stroke-width="10"
        stroke-dasharray={`${medLen} ${c - medLen}`}
        stroke-dashoffset={`-${ssLen}`}
      />
      <g transform="rotate(90, 50, 50)">
        <text
          x="50"
          y="48"
          text-anchor="middle"
          class="fill-slate-900 dark:fill-slate-100"
          font-size="13"
          font-weight="700"
        >
          {(total * 100).toFixed(1)}%
        </text>
        <text
          x="50"
          y="60"
          text-anchor="middle"
          class="fill-slate-500 dark:fill-slate-400"
          font-size="6"
        >
          SE tax
        </text>
      </g>
    </svg>
    <div class="mt-4 grid grid-cols-2 gap-4 text-sm">
      <div class="flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded-full bg-indigo-600"></span>
        <span><strong>{(ss * 100).toFixed(1)}%</strong> Social Security</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded-full bg-emerald-500"></span>
        <span><strong>{(med * 100).toFixed(1)}%</strong> Medicare</span>
      </div>
    </div>
  </div>
  <figcaption class="mt-2 text-center text-xs text-slate-500 dark:text-slate-400">
    The two halves of 2026 self-employment tax. Social Security applies up to
    a wage base of ${SE_TAX.socialSecurityWageBase.toLocaleString()}; Medicare has no cap.
  </figcaption>
</figure>

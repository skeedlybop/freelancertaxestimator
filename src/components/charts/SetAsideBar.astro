---
/**
 * SetAsideBar — horizontal bar chart of set-aside % across income tiers.
 * Computed live from the same estimate() engine the calculator uses, so the
 * chart can't drift from the math.
 */
import { estimate, TAX_YEAR } from "@/data/tax-constants";

const incomes = [20000, 40000, 60000, 80000, 100000, 150000];
const data = incomes.map((income) => {
  const r = estimate({
    grossSEIncome: income,
    businessExpenses: 0,
    filingStatus: "single",
  });
  return {
    income,
    pct: r.setAsidePct * 100,
    dollars: r.totalTax,
  };
});

const maxPct = Math.max(...data.map((d) => d.pct));
---

<figure class="my-8 mx-auto max-w-2xl">
  <div class="card p-5 md:p-6">
    <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
      Federal set-aside % by net profit (single filer, {TAX_YEAR})
    </p>
    <div role="img" aria-label="Bar chart showing federal tax set-aside percentage rising with net profit" class="space-y-2.5">
      {data.map((d) => {
        const width = (d.pct / Math.max(maxPct, 35)) * 100;
        return (
          <div class="flex items-center gap-3">
            <span class="w-20 text-right text-sm font-medium tabular-nums">
              ${(d.income / 1000).toFixed(0)}k
            </span>
            <div class="flex-1 h-7 rounded-md bg-slate-100 dark:bg-slate-800 overflow-hidden relative">
              <div
                class="h-full rounded-md bg-gradient-to-r from-indigo-500 to-indigo-600"
                style={`width: ${width}%`}
              ></div>
              <span class="absolute inset-y-0 left-2 flex items-center text-xs font-semibold text-white drop-shadow">
                {d.pct.toFixed(1)}%
              </span>
            </div>
            <span class="w-24 text-right text-xs text-slate-500 tabular-nums dark:text-slate-400">
              ≈ ${Math.round(d.dollars).toLocaleString()}
            </span>
          </div>
        );
      })}
    </div>
    <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">
      Federal only — SE tax + income tax across the {TAX_YEAR} brackets. Add
      0–13% on top for state income tax.
    </p>
  </div>
  <figcaption class="mt-2 text-center text-xs text-slate-500 dark:text-slate-400">
    Why "set aside 30%" works as a starting point, and why high earners should lean higher.
  </figcaption>
</figure>

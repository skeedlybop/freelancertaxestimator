---
export interface FAQItem {
  q: string;
  a: string;
}
export interface Props {
  items: FAQItem[];
  heading?: string;
  emitSchema?: boolean;
}
const { items, heading = "Frequently asked", emitSchema = true } = Astro.props;

const faqLd = emitSchema
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: items.map(({ q, a }) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    }
  : null;
---

<section class="mt-10">
  <h2 class="mb-4 text-xl font-bold md:text-2xl">{heading}</h2>
  <div class="space-y-3">
    {
      items.map((item) => (
        <details class="group rounded-xl border border-slate-200 bg-white p-4 open:shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <summary class="cursor-pointer list-none font-medium marker:hidden">
            <span class="mr-2 inline-block transition-transform group-open:rotate-90">
              ›
            </span>
            {item.q}
          </summary>
          <p class="mt-3 text-slate-700 dark:text-slate-300">{item.a}</p>
        </details>
      ))
    }
  </div>
  {
    faqLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(faqLd)}
      />
    )
  }
</section>

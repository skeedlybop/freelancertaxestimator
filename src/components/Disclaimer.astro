---
export interface Props {
  variant?: "full" | "short";
}
const { variant = "full" } = Astro.props;
---

{
  variant === "short" ? (
    <p class="mt-6 rounded-xl border border-amber-300 bg-amber-50 px-4 py-3 text-xs leading-relaxed text-amber-900 dark:border-amber-900/60 dark:bg-amber-950/40 dark:text-amber-100">
      <strong>Estimates only.</strong> This calculator is informational and is
      not tax, legal, or financial advice. Confirm your situation with a
      qualified tax professional before filing or making payments.
    </p>
  ) : (
    <aside class="mt-10 rounded-2xl border border-amber-300 bg-amber-50 p-5 text-sm leading-relaxed text-amber-900 dark:border-amber-900/60 dark:bg-amber-950/40 dark:text-amber-100">
      <p class="mb-2 font-semibold">Disclaimer</p>
      <p>
        FreelancerTaxEstimator is an independent educational resource. Content
        and calculations on this site are <strong>informational only</strong>{" "}
        and are not tax, legal, accounting, or financial advice. Tax figures are
        sourced from IRS.gov and verified annually, but rules change and
        individual situations vary. Before making filing or payment decisions,
        consult a qualified tax professional (CPA, EA, or attorney) who can
        review your specific circumstances.
      </p>
    </aside>
  )
}
